@model IEnumerable<ArtGestion.Models.Alerte>

@{
    ViewData["Title"] = "Alertes";
}

<h2>Alertes d'expiration</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Type</th>
            <th>Message</th>
            <th>Date génération</th>
            <th>État</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>
                @if (item.TypeAlerte == "Expiré")
                {
                    <span class="badge bg-danger">Expiré</span>
                }
                else if (item.TypeAlerte == "Bientôt expiré")
                {
                    <span class="badge bg-warning text-dark">Bientôt expiré</span>
                }
                else
                {
                    <span class="badge bg-secondary">@item.TypeAlerte</span>
                }
            </td>
            <td>@item.Message</td>
            <td>@item.DateGeneration.ToString("dd/MM/yyyy HH:mm")</td>
            <td>
                @if (item.EstLue)
                {
                    <span class="badge bg-success">Lue</span>
                }
                else
                {
                    <span class="badge bg-danger">Non lue</span>
                }
            </td>
            <td>
                @if (!item.EstLue)
                {
                    <a asp-controller="Alertes"
                       asp-action="MarquerCommeLue"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-primary">
                        Voir
                    </a>
                }
                else
                {
                    <span class="text-muted">Déjà lue</span>
                }
            </td>
        </tr>
    }
    </tbody>
</table>