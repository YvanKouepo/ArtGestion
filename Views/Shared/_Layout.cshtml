<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ArtGestion</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArtGestion.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
    <div class="container-fluid">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">ArtGestion</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <script>
    setInterval(function () {
        fetch('/Alertes/GetNonLuesCount')
            .then(res => res.json())
            .then(data => {
                document.getElementById('alertesBadge').innerText = data;
            });
    }, 5000); // toutes les 5 secondes
</script>
        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
        <ul class="navbar-nav">
     
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <li class="nav-item">
            <span class="nav-link text-dark">Bonjour, @User.Identity.Name</span>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Logout">Déconnexion</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Connexion</a>
        </li>
    }
       @if (User.IsInRole("SuperAdmin"))
{
    <li class="nav-item">
        <a class="nav-link text-dark" asp-controller="Services" asp-action="Index">Services</a>
    </li>
    @if (User.IsInRole("SuperAdmin"))
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="Users" asp-action="Index">Utilisateurs</a>
    </li>
}
}
</ul>
            <ul class="navbar-nav flex-grow-1">
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Exploitants" asp-action="Index">Exploitants</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="TitresExploitation" asp-action="Index">Titres</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Alertes" asp-action="Index">
                        Alertes @await Component.InvokeAsync("AlertesBadge")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="LogsActions" asp-action="Index">Logs</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                </li>
            </ul>
        </div>
    </div>
</nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ArtGestion - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @await Component.InvokeAsync("AlertesBadge")
</body>
</html>
