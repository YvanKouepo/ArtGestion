@model ArtGestion.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Tableau de bord";
}

<h2>Tableau de bord</h2>

<div class="row">
    <div class="col-md-2">
        <div class="card bg-primary text-white mb-3">
            <div class="card-body">
                <h6>Exploitants</h6>
                <h3>@Model.TotalExploitants</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card bg-dark text-white mb-3">
            <div class="card-body">
                <h6>Total titres</h6>
                <h3>@Model.TotalTitres</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card bg-success text-white mb-3">
            <div class="card-body">
                <h6>Actifs</h6>
                <h3>@Model.Actifs</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card bg-warning text-dark mb-3">
            <div class="card-body">
                <h6>Bientôt expirés</h6>
                <h3>@Model.BientotExpires</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card bg-danger text-white mb-3">
            <div class="card-body">
                <h6>Expirés</h6>
                <h3>@Model.Expires</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card bg-info text-white mb-3">
            <div class="card-body">
                <h6>Alertes non lues</h6>
                <h3>@Model.AlertesNonLues</h3>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Exploitants par région</div>
            <div class="card-body">
                <canvas id="regionsChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Titres par type</div>
            <div class="card-body">
                <canvas id="typesTitreChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const regionsLabels = @Html.Raw(JsonSerializer.Serialize(Model.RegionsLabels));
    const regionsCounts = @Html.Raw(JsonSerializer.Serialize(Model.RegionsCounts));

    const typesTitreLabels = @Html.Raw(JsonSerializer.Serialize(Model.TypesTitreLabels));
    const typesTitreCounts = @Html.Raw(JsonSerializer.Serialize(Model.TypesTitreCounts));

    new Chart(document.getElementById('regionsChart'), {
        type: 'bar',
        data: {
            labels: regionsLabels,
            datasets: [{
                label: 'Exploitants',
                data: regionsCounts
            }]
        }
    });

    new Chart(document.getElementById('typesTitreChart'), {
        type: 'pie',
        data: {
            labels: typesTitreLabels,
            datasets: [{
                label: 'Titres',
                data: typesTitreCounts
            }]
        }
    });
</script>